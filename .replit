modules = ["python-3.11", "tkinter"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["vim", "python312Packages.tkinter", "tcl", "tk", "python312Full", "python3Full"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sleep 2"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"

[workflows.workflow.metadata]
outputType = "vnc"

[deployment]
deploymentTarget = "vm"
run = ["python", "main.py"]
